<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reimposta Password - Stook</title>

  <link href="https://fonts.googleapis.com/css2?family=Luckiest+Guy&display=swap" rel="stylesheet">

  <style>
    :root {
      --text: #000000;
      --bg: #ffffff;
      --card: #f8f8f8;
      --muted: #666;
      --border: #e6e6e6;
      --success-bg: #f1f7f1;
      --success-border: #cfe3cf;
      --error-bg: #fff2f2;
      --error-border: #ecc9c9;
      --error-text: #7a1f1f;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .topbar {
      width: 100%;
      padding: 14px 16px;
    }

    .brand {
      display: inline-block;
      font-family: 'Luckiest Guy', cursive;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 1.5rem;
      line-height: 1;
      color: var(--text);
      text-decoration: none;
    }

    main {
      min-height: calc(100vh - 58px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 20px 48px;
    }

    .card {
      width: min(100%, 560px);
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 38px 30px 32px;
      text-align: left;
    }

    h1 {
      margin: 0 0 12px;
      font-size: clamp(2rem, 4vw, 3rem);
      text-align: center;
    }

    .intro {
      margin: 0 0 28px;
      color: var(--muted);
      text-align: center;
      font-size: 1rem;
      line-height: 1.6;
    }

    .field {
      margin-bottom: 18px;
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-weight: 700;
      font-size: 0.96rem;
    }

    input {
      width: 100%;
      padding: 14px 16px;
      border: 1px solid #d3d3d3;
      border-radius: 14px;
      font-size: 1rem;
      background: #ffffff;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    input:focus {
      border-color: #000000;
      box-shadow: 0 0 0 4px rgba(0, 0, 0, 0.08);
    }

    .cta-btn {
      display: inline-block;
      width: 100%;
      background: #000000;
      color: #ffffff;
      padding: 14px 28px;
      border-radius: 14px;
      text-decoration: none;
      font-weight: 700;
      font-size: 1rem;
      text-align: center;
      transition: transform 0.08s ease, background 0.3s ease;
      cursor: pointer;
      border: none;
      margin-top: 8px;
    }

    .cta-btn:hover {
      background: #333333;
      transform: translateY(-1px);
    }

    .message {
      margin-top: 18px;
      padding: 16px 18px;
      border-radius: 16px;
      line-height: 1.6;
      font-size: 0.95rem;
      display: none;
    }

    .message.success {
      background: var(--success-bg);
      border: 1px solid var(--success-border);
      color: #234023;
    }

    .message.error {
      background: var(--error-bg);
      border: 1px solid var(--error-border);
      color: var(--error-text);
    }

    .back-link {
      display: inline-block;
      margin-top: 18px;
      color: var(--text);
      text-decoration: none;
      font-weight: 600;
    }

    .back-link:hover {
      text-decoration: underline;
    }

    @media (max-width: 520px) {
      .topbar {
        padding: 12px 14px;
      }

      .card {
        padding: 30px 20px 24px;
        border-radius: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="topbar">
    <a href="index.html" class="brand">STOOK</a>
  </div>

  <main>
    <section class="card">
      <h1>Reimposta password</h1>
      <p class="intro">Conferma la tua email e scegli una nuova password per aggiornare l'accesso al tuo profilo Stook.</p>

      <form id="reset-form" method="post" action="#" autocomplete="on">
        <div class="field">
          <label for="reset-email">Email</label>
          <input type="email" id="reset-email" name="email" placeholder="nome@email.com" autocomplete="email" inputmode="email" required>
        </div>

        <div class="field">
          <label for="new-password">Nuova password</label>
          <input type="password" id="new-password" name="new-password" placeholder="Crea una nuova password" autocomplete="new-password" required>
        </div>

        <div class="field">
          <label for="confirm-password">Conferma nuova password</label>
          <input type="password" id="confirm-password" name="confirm-password" placeholder="Riscrivi la nuova password" autocomplete="new-password" required>
        </div>

        <button type="submit" class="cta-btn">Salva nuova password</button>
      </form>

      <div id="reset-success" class="message success"></div>
      <div id="reset-error" class="message error"></div>

      <a href="accedi.html" class="back-link">Torna ad accedi</a>
    </section>
  </main>

  <script>
    const params = new URLSearchParams(window.location.search);
    const resetEmailInput = document.getElementById('reset-email');
    const newPasswordInput = document.getElementById('new-password');
    const confirmPasswordInput = document.getElementById('confirm-password');
    const resetForm = document.getElementById('reset-form');
    const resetSuccess = document.getElementById('reset-success');
    const resetError = document.getElementById('reset-error');
    const emailFromLink = params.get('email');

    if (emailFromLink) {
      resetEmailInput.value = emailFromLink;
    }

    resetForm.addEventListener('submit', function (event) {
      event.preventDefault();

      resetSuccess.style.display = 'none';
      resetError.style.display = 'none';

      const email = resetEmailInput.value.trim();
      const newPassword = newPasswordInput.value;
      const confirmPassword = confirmPasswordInput.value;

      if (newPassword !== confirmPassword) {
        resetError.textContent = 'Le password non coincidono. Controlla i campi e riprova.';
        resetError.style.display = 'block';
        return;
      }

      resetSuccess.innerHTML = 'Password aggiornata con successo per <strong>' + email + '</strong>.<br><br>Nel flusso reale, da qui collegheremo la nuova password al profilo esistente e potrai tornare al login.';
      resetSuccess.style.display = 'block';
      resetForm.reset();

      if (email) {
        resetEmailInput.value = email;
      }
    });
  </script>
</body>
</html>
